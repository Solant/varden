{
  "name": "varden",
  "version": "0.1.3",
  "description": "A lightweight, type-safe and reliable form validation library for Vue 3",
  "author": "Solant",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "homepage": "https://github.com/Solant/varden#readme",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "keywords": [
    "vue",
    "vue3",
    "form",
    "forms",
    "validation",
    "validator",
    "schema",
    "typescript",
    "type-safe",
    "composable"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Solant/varden.git"
  },
  "bugs": {
    "url": "https://github.com/Solant/varden/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.js",
  "jsdelivr": "./dist/index.js",
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "test": "vitest --coverage",
    "release": "pnpm test && pnpm build && pnpm changelogen --release --push && pnpm publish"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/tsconfig": "^0.8.1",
    "changelogen": "^0.6.2",
    "tsdown": "^0.21.6",
    "typescript": "~6.0.2",
    "unplugin-vue": "^7.1.1",
    "valibot": "^1.3.1",
    "vite-bundle-explorer": "^0.3.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "vue": "^3.5.13"
  },
  "dependencies": {
    "eslint-plugin-import-x": "^4.16.2"
  }
}
